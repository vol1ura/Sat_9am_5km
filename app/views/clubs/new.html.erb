<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <%= link_to t('.main_page'), root_path %>
    </li>
    <li class="breadcrumb-item">
      <%= link_to t('.clubs'), clubs_path %>
    </li>
    <li class="breadcrumb-item active" aria-current="page"><%= t('.title') %></li>
  </ol>
</nav>

<h1><%= head_info :title, t('.title') %></h1>
<p><%= head_info :description, t('.description') %></p>

<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: clubs_path, local: true do |form| %>
      <div class="mb-3">
        <%= form.label :name, t('.club_name'), class: 'form-label' %>
        <%= form.text_field :name, class: 'form-control', required: true, maxlength: 100 %>
      </div>

      <div class="mb-3">
        <%= form.label :description, t('.club_description'), class: 'form-label' %>
        <%= form.text_area :description, class: 'form-control', required: true, rows: 5, minlength: 50 %>
        <div class="form-text"><%= t('.description_hint') %></div>
      </div>

      <div class="mb-3">
        <%= form.label :logo, t('.club_logo'), class: 'form-label' %>
        <%= form.file_field :logo, class: 'form-control', accept: 'image/*' %>
        <div class="form-text"><%= t('.logo_hint') %></div>
      </div>

      <%= form.submit t('.submit'), class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>
