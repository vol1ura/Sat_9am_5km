<% closest_date = @activity&.date ? l(@activity.date, format: :brief) : t('.closest_date') %>
<% head_info :title, t('.title', event: @event.name, date: closest_date) %>
<% head_info :description, t('.description', event: @event.name, date: closest_date) %>
<%= turbo_stream_from :volunteers_roster %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <%= link_to t('.main_page'), root_path %>
    </li>
    <li class="breadcrumb-item">
      <%= link_to @event.name, event_path(@event.code_name) %>
    </li>
    <li class="breadcrumb-item active" aria-current="page"><%= t '.main_title' %></li>
  </ol>
</nav>

<h1><%= t '.main_title' %></h1>

<p><%= t '.acknowledgements' %></p>
<p>
  <% unless @activities.empty? %>
    <%= t '.about_roster_html' %>
  <% end %>
  <%= t '.how_to_participate' %>
  <% if @tg_chat %>
    <%= t '.how_to_participate_html', tg_chat_link: @tg_chat.link %>
  <% end %>
  <%= t '.additional_positions' %>
</p>

<% unless @activities.empty? %>
  <ul class="nav nav-tabs" id="protocol" role="tablist">
    <% @activities.each_with_index do |activity, tab_idx| %>
      <li class="nav-item" role="presentation">
        <%=
          link_to(
            l(activity.date, format: :brief),
            volunteering_event_path(@event.code_name, activity_id: activity.id),
            class: "nav-link #{'active' if activity.id == @activity&.id || (tab_idx.zero? && @activity.nil?)}",
            role: 'tab',
          )
        %>
      </li>
    <% end %>
  </ul>

  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th class="w-auto"></th>
          <th><%= t '.volunteer' %></th>
        </tr>
      </thead>
      <% if @activity %>
        <tbody class="table-group-divider" data-turbo-prefetch="false">
          <%
            all_volunteers = @activity.volunteers.includes(:athlete).to_a
            volunteering_positions = @activity.volunteering_positions_roster
            volunteering_positions_roles = volunteering_positions.map(&:role)
            any_open_slot = false
          %>
          <% volunteering_positions.each do |position| %>
            <% volunteers = all_volunteers.select { |v| v.role == position.role }.sort_by { |v| v.comment.to_s } %>
            <% filled = volunteers.size %>
            <% total = position.number %>
            <% any_open_slot ||= filled < total %>
            <tr class="table-light">
              <td colspan="2" class="py-2">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                  <span class="fw-semibold"><%= human_volunteer_role position.role %></span>
                  <span class="d-flex align-items-center gap-2">
                    <div class="progress" style="width: 100px; height: 8px;">
                      <div
                        class="progress-bar <%= filled >= total ? 'bg-success' : 'bg-primary' %>"
                        style="width: <%= total.positive? ? (100.0 * [filled, total].min / total).round : 0 %>%"
                      ></div>
                    </div>
                    <span class="text-muted small text-nowrap">
                      <%= t '.slots_filled', filled:, total: %>
                    </span>
                  </span>
                </div>
              </td>
            </tr>
            <% [total, filled].max.times.each do |i| %>
              <%
                volunteer = volunteers[i]
                idx = "#{position.role}-#{i}-#{@activity.id}"
              %>
              <tr>
                <td class="text-muted small text-center"><%= i + 1 %></td>
                <td>
                  <%= render partial: 'role', locals: { volunteer: volunteer, role: position.role, idx: idx } %>
                  <%= render partial: 'volunteer', locals: { volunteer: volunteer, role: position.role, idx: idx, activity: @activity, my_volunteering: @my_volunteering, organizer: @volunteer_organizer, tg_chat: @tg_chat } %>
                </td>
              </tr>
            <% end %>
          <% end %>
          <% extra_volunteers = all_volunteers.reject { |v| v.role.in?(volunteering_positions_roles) }.sort_by { |v| [v.role, v.comment.to_s] } %>
          <% if extra_volunteers.any? %>
            <tr class="table-light">
              <td colspan="2" class="py-2 fw-semibold"><%= t '.extra_volunteers_header' %></td>
            </tr>
            <% extra_volunteers.each do |volunteer| %>
              <% idx = "#{volunteer.role}-#{volunteer.id}-#{@activity.id}" %>
              <tr>
                <td></td>
                <td>
                  <%= render partial: 'role', locals: { volunteer: volunteer, role: volunteer.role, idx: idx, show_role: true } %>
                  <%= render partial: 'volunteer', locals: { volunteer: volunteer, role: volunteer.role, idx: idx, activity: @activity, my_volunteering: @my_volunteering, organizer: @volunteer_organizer, tg_chat: @tg_chat } %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      <% end %>
    </table>
  </div>

  <% if @activity && !any_open_slot %>
    <div class="alert alert-info"><%= t '.all_slots_full' %></div>
  <% end %>
<% end %>
