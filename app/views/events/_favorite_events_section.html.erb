<%= tag.div id: 'favorite_events_section' do %>
  <% if user_signed_in? && current_user.favorite_event_ids.any? %>
    <h3 class="mb-3"><%= t '.title' %></h3>
    <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
      <% current_user.favorite_events.each do |event| %>
        <div class="col">
          <%= tag.div class: ['card-with-border', event.active ? 'border-primary' : 'border-danger'] do %>
            <div class="overflow-hidden card-img-top">
              <%= event_main_image_tag event, variant: :thumb, class: 'img-fluid rounded-top img-scaled', alt: event.name, loading: 'lazy' %>
            </div>
            <%= tag.div class: ['position-absolute', 'top-0', 'bg-gradient', 'bg-opacity-25', 'w-100', 'px-3', 'card-img-top', 'd-flex', 'justify-content-between', 'align-items-start', event.active ? 'bg-dark' : 'bg-danger'] do %>
              <section class="fs-4 text-light"><%= event.name %></section>
              <%= render 'favorite_events/heart', event: %>
            <% end %>
            <div class="card-body">
              <p class="card-text">
                <%= link_to "#{event.place} (#{event.town})", event_path(event.code_name), class: 'stretched-link text-decoration-none text-body' %>
              </p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <hr class="mb-4">
    <h3 class="mb-3"><%= t '.all_events' %></h3>
  <% end %>
<% end %>
