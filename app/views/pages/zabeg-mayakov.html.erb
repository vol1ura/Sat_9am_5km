<script src="/js/zabeg-mayakov/gsap.min.js"></script>
<script src="/js/zabeg-mayakov/ScrollTrigger.min.js"></script>

<script>
    (function() {
        const beam = document.getElementById('lighthouse-beam');
        let mouseX = 0, mouseY = 0, curX = 0, curY = 0;
        document.addEventListener('mousemove', e => { mouseX = e.clientX; mouseY = e.clientY; });
        function animateBeam() {
            curX += (mouseX - curX) * 0.1; curY += (mouseY - curY) * 0.1;
            beam.style.setProperty('--x', `${curX}px`); beam.style.setProperty('--y', `${curY}px`);
            requestAnimationFrame(animateBeam);
        }
        animateBeam();

        if (window.gsap) {
            gsap.registerPlugin(ScrollTrigger);
            gsap.from("#mayakov-title", { duration: 1.8, y: 100, opacity: 0, ease: "power4.out", delay: 0.3 });
            document.querySelectorAll('.reveal-item').forEach(el => {
                gsap.from(el, { scrollTrigger: { trigger: el, start: "top 85%" }, y: 50, opacity: 0, duration: 1.2, ease: "power3.out" });
            });
        }
    })();
</script>
