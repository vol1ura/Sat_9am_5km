<% head_info :description, t('.description') %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <h1><%= head_info :title, t('.title') %></h1>
    <p><%= t '.email_login_description' %></p>
    <%= form_with url: email_sessions_path, method: :post, data: { turbo: false } do |f| %>
      <div class="input-group mb-3">
        <%= f.email_field :email, autofocus: true, autocomplete: :email, inputmode: :email, class: 'form-control', placeholder: t('.email_placeholder'), required: true %>
        <%= f.submit t('.email_submit'), class: 'btn btn-outline-primary' %>
      </div>
    <% end %>
    <hr class="my-4">
    <p><%= t '.email_registration_description' %></p>
    <p class="text-center">
      <%= link_to t('.email_registration_link'), new_user_registration_path, class: 'btn btn-outline-danger' %>
    </p>
    <% if top_level_domain == :ru %>
      <p class="h5 mt-5">Альтернативный способ входа</p>
      <p>
        Если способ с получением ссылки по какой-то причине вам не подходит,
        можете воспользоваться входом по номеру вашего телефона (если вы регистрировались через бота).
        После подтверждения запроса от Telegram, вы сможете легко входить нажатием на эту кнопку.
      </p>
      <p class="text-body-secondary small">
        В связи с ограничениями работы Telegram, данный способ может не работать. Кнопка будет недоступна.
      </p>
      <div class="mt-3 text-center">
        <script async src="https://telegram.org/js/telegram-widget.js?22" data-telegram-login="sat9am5kmbot" data-size="large" data-radius="5" data-auth-url="<%= user_telegram_omniauth_callback_url %>" data-request-access="write"></script>
      </div>
    <% end %>
  </div>
</div>
