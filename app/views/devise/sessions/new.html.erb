<% head_info :description, t('.description') %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <h1><%= head_info :title, t('.title') %></h1>
    <p class="my-3"><span class="fa-li"><i class="fa-solid fa-robot"></i></span>
      <%= t '.registration_html', link: 'https://t.me/sat9am5kmbot' %>
    </p>
    <div class="alert alert-info" role="alert">
      <i class="fa-solid fa-robot"></i>
      <%= t '.telegram_login_html', link: 'https://t.me/sat9am5kmbot' %>
    </div>
    <p class="h5"><%= t '.email_login_title' %></p>
    <p><%= t '.email_login_description' %></p>
    <p class="text-center">
      <%= link_to t('.email_login_link'), new_email_session_path, class: 'btn btn-outline-primary' %>
    </p>
    <% if top_level_domain == :ru %>
      <p class="h5 mt-5">Ещё один способ входа</p>
      <p>
        Если способы с получением ссылки по какой-то причине вам не подходят,
        можете воспользоваться входом по номеру вашего телефона (с которого регистрировались в боте).
        После подтверждения запроса от Telegram, вы сможете легко входить нажатием на эту кнопку.
      </p>
      <p class="text-body-secondary small">
        В связи с ограничениями работы Telegram, данный способ может не работать. Кнопка будет недоступна.
      </p>
      <div class="mt-3 text-center">
        <script async src="https://telegram.org/js/telegram-widget.js?22" data-telegram-login="sat9am5kmbot" data-size="large" data-radius="5" data-auth-url="<%= user_telegram_omniauth_callback_url %>" data-request-access="write"></script>
      </div>
    <% end %>
  </div>
</div>
