<% head_info :description, t('.description') %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <h1 class="mb-4"><%= head_info :title, t('.title') %></h1>

    <%= form_with url: email_sessions_path, method: :post, data: { turbo: false } do |f| %>
      <div class="mb-3">
        <%=
          f.email_field(
            :email,
            autofocus: true,
            autocomplete: :email,
            inputmode: :email,
            class: 'form-control',
            placeholder: t('.email_label'),
            required: true,
          )
        %>
      </div>

      <div class="d-grid gap-2">
        <%= f.submit t('.submit'), class: 'btn btn-primary' %>
      </div>
    <% end %>

    <div class="mt-3 text-center">
      <%= link_to t('.back_to_login'), new_user_session_path, class: 'text-secondary small' %>
    </div>
  </div>
</div>
